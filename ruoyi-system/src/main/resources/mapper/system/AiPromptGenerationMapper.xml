<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiPromptGenerationMapper">

    <insert id="insertAiPromptGeneration" parameterType="com.ruoyi.system.domain.AiPromptGeneration">
        insert into ai_prompt_generation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userInput != null">user_input,</if>
            <if test="generatedPrompt != null">generated_prompt,</if>
            <if test="templateType != null">template_type,</if>
            <if test="llmConfigId != null">llm_config_id,</if>
            <if test="modelName != null">model_name,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userInput != null">#{userInput},</if>
            <if test="generatedPrompt != null">#{generatedPrompt},</if>
            <if test="templateType != null">#{templateType},</if>
            <if test="llmConfigId != null">#{llmConfigId},</if>
            <if test="modelName != null">#{modelName},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">now(),</if>
        </trim>
    </insert>

</mapper>

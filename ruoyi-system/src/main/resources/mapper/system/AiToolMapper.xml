<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiToolMapper">

    <resultMap type="com.ruoyi.system.domain.AiTool" id="AiToolResult">
        <result property="toolId" column="tool_id"/>
        <result property="toolName" column="tool_name"/>
        <result property="toolCode" column="tool_code"/>
        <result property="toolDesc" column="tool_desc"/>
        <result property="functionSchema" column="function_schema"/>
        <result property="handlerClass" column="handler_class"/>
        <result property="isBuiltin" column="is_builtin"/>
        <result property="status" column="status"/>
        <result property="sort" column="sort"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectToolVo">
        select tool_id, tool_name, tool_code, tool_desc, function_schema, handler_class,
               is_builtin, status, sort, remark, create_by, create_time, update_by, update_time
        from ai_tool
    </sql>

    <select id="selectAiToolList" parameterType="com.ruoyi.system.domain.vo.AiToolQuery" resultMap="AiToolResult">
        <include refid="selectToolVo"/>
        <where>
            <if test="toolName != null and toolName != ''">
                AND tool_name like concat('%', #{toolName}, '%')
            </if>
            <if test="toolCode != null and toolCode != ''">
                AND tool_code = #{toolCode}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="isBuiltin != null and isBuiltin != ''">
                AND is_builtin = #{isBuiltin}
            </if>
        </where>
        order by sort asc, tool_id asc
    </select>

    <select id="selectAiToolById" parameterType="Long" resultMap="AiToolResult">
        <include refid="selectToolVo"/>
        where tool_id = #{toolId}
    </select>

    <select id="selectEnabledTools" resultMap="AiToolResult">
        <include refid="selectToolVo"/>
        where status = '0'
        order by sort asc, tool_id asc
    </select>

    <insert id="insertAiTool" parameterType="com.ruoyi.system.domain.AiTool" useGeneratedKeys="true" keyProperty="toolId">
        insert into ai_tool
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="toolName != null and toolName != ''">tool_name,</if>
            <if test="toolCode != null and toolCode != ''">tool_code,</if>
            <if test="toolDesc != null">tool_desc,</if>
            <if test="functionSchema != null">function_schema,</if>
            <if test="handlerClass != null">handler_class,</if>
            <if test="isBuiltin != null">is_builtin,</if>
            <if test="status != null">status,</if>
            <if test="sort != null">sort,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="toolName != null and toolName != ''">#{toolName},</if>
            <if test="toolCode != null and toolCode != ''">#{toolCode},</if>
            <if test="toolDesc != null">#{toolDesc},</if>
            <if test="functionSchema != null">#{functionSchema},</if>
            <if test="handlerClass != null">#{handlerClass},</if>
            <if test="isBuiltin != null">#{isBuiltin},</if>
            <if test="status != null">#{status},</if>
            <if test="sort != null">#{sort},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">now(),</if>
        </trim>
    </insert>

    <update id="updateAiTool" parameterType="com.ruoyi.system.domain.AiTool">
        update ai_tool
        <trim prefix="SET" suffixOverrides=",">
            <if test="toolName != null and toolName != ''">tool_name = #{toolName},</if>
            <if test="toolCode != null and toolCode != ''">tool_code = #{toolCode},</if>
            <if test="toolDesc != null">tool_desc = #{toolDesc},</if>
            <if test="functionSchema != null">function_schema = #{functionSchema},</if>
            <if test="handlerClass != null">handler_class = #{handlerClass},</if>
            <if test="isBuiltin != null">is_builtin = #{isBuiltin},</if>
            <if test="status != null">status = #{status},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = now(),</if>
        </trim>
        where tool_id = #{toolId}
    </update>

    <delete id="deleteAiToolById" parameterType="Long">
        delete from ai_tool where tool_id = #{toolId}
    </delete>

    <delete id="deleteAiToolByIds" parameterType="Long">
        delete from ai_tool where tool_id in
        <foreach item="toolId" collection="array" open="(" separator="," close=")">
            #{toolId}
        </foreach>
    </delete>

</mapper>

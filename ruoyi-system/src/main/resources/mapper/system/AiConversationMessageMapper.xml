<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiConversationMessageMapper">

    <resultMap type="com.ruoyi.system.domain.AiConversationMessage" id="AiConversationMessageResult">
        <result property="messageId" column="message_id"/>
        <result property="conversationId" column="conversation_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="tokenCount" column="token_count"/>
        <result property="toolCalls" column="tool_calls"/>
        <result property="metadata" column="metadata"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectMessageVo">
        select message_id, conversation_id, role, content, token_count,
               tool_calls, metadata, create_time
        from ai_conversation_message
    </sql>

    <select id="selectAiConversationMessageById" parameterType="Long" resultMap="AiConversationMessageResult">
        <include refid="selectMessageVo"/>
        where message_id = #{messageId}
    </select>

    <select id="selectAiConversationMessageList" parameterType="com.ruoyi.system.domain.AiConversationMessage" resultMap="AiConversationMessageResult">
        <include refid="selectMessageVo"/>
        where conversation_id = #{conversationId}
        order by create_time asc
    </select>

    <select id="selectRecentMessages" resultMap="AiConversationMessageResult">
        <include refid="selectMessageVo"/>
        where conversation_id = #{conversationId}
        order by create_time desc
        limit #{limit}
    </select>

    <select id="selectMessageCount" parameterType="Long" resultType="int">
        select count(1) from ai_conversation_message where conversation_id = #{conversationId}
    </select>

    <insert id="insertAiConversationMessage" parameterType="com.ruoyi.system.domain.AiConversationMessage" useGeneratedKeys="true" keyProperty="messageId">
        insert into ai_conversation_message
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="conversationId != null">conversation_id,</if>
            <if test="role != null">role,</if>
            <if test="content != null">content,</if>
            <if test="tokenCount != null">token_count,</if>
            <if test="toolCalls != null">tool_calls,</if>
            <if test="metadata != null">metadata,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="conversationId != null">#{conversationId},</if>
            <if test="role != null">#{role},</if>
            <if test="content != null">#{content},</if>
            <if test="tokenCount != null">#{tokenCount},</if>
            <if test="toolCalls != null">#{toolCalls},</if>
            <if test="metadata != null">#{metadata},</if>
            sysdate()
        </trim>
    </insert>

    <delete id="deleteAiConversationMessageByConversationId" parameterType="Long">
        delete from ai_conversation_message where conversation_id = #{conversationId}
    </delete>

    <delete id="deleteAiConversationMessageByIds" parameterType="String">
        delete from ai_conversation_message where message_id in
        <foreach collection="array" item="messageId" open="(" separator="," close=")">
            #{messageId}
        </foreach>
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiLlmConfigMapper">

    <resultMap type="com.ruoyi.system.domain.AiLlmConfig" id="AiLlmConfigResult">
        <result property="configId" column="config_id"/>
        <result property="configName" column="config_name"/>
        <result property="provider" column="provider"/>
        <result property="providerName" column="provider_name"/>
        <result property="baseUrl" column="base_url"/>
        <result property="apiKey" column="api_key"/>
        <result property="defaultModel" column="default_model"/>
        <result property="status" column="status"/>
        <result property="isDefault" column="is_default"/>
        <result property="sort" column="sort"/>
        <result property="remark" column="remark"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectConfigVo">
        select config_id, config_name, provider, provider_name, base_url, api_key,
               default_model, status, is_default, sort, remark, create_by, create_time, update_by, update_time
        from ai_llm_config
    </sql>

    <select id="selectAiLlmConfigList" parameterType="com.ruoyi.system.domain.vo.AiLlmConfigQuery" resultMap="AiLlmConfigResult">
        <include refid="selectConfigVo"/>
        <where>
            <if test="configName != null and configName != ''">
                AND config_name like concat('%', #{configName}, '%')
            </if>
            <if test="provider != null and provider != ''">
                AND provider = #{provider}
            </if>
            <if test="providerName != null and providerName != ''">
                AND provider_name like concat('%', #{providerName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="isDefault != null and isDefault != ''">
                AND is_default = #{isDefault}
            </if>
        </where>
        order by sort asc, create_time desc
    </select>

    <select id="selectAiLlmConfigById" parameterType="Long" resultMap="AiLlmConfigResult">
        <include refid="selectConfigVo"/>
        where config_id = #{configId}
    </select>

    <select id="selectDefaultByProvider" resultMap="AiLlmConfigResult">
        <include refid="selectConfigVo"/>
        where provider = #{provider} and is_default = '1' and status = '0'
        limit 1
    </select>

    <insert id="insertAiLlmConfig" parameterType="com.ruoyi.system.domain.AiLlmConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into ai_llm_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name,</if>
            <if test="provider != null and provider != ''">provider,</if>
            <if test="providerName != null and providerName != ''">provider_name,</if>
            <if test="baseUrl != null">base_url,</if>
            <if test="apiKey != null">api_key,</if>
            <if test="defaultModel != null">default_model,</if>
            <if test="status != null">status,</if>
            <if test="isDefault != null">is_default,</if>
            <if test="sort != null">sort,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="configName != null and configName != ''">#{configName},</if>
            <if test="provider != null and provider != ''">#{provider},</if>
            <if test="providerName != null and providerName != ''">#{providerName},</if>
            <if test="baseUrl != null">#{baseUrl},</if>
            <if test="apiKey != null">#{apiKey},</if>
            <if test="defaultModel != null">#{defaultModel},</if>
            <if test="status != null">#{status},</if>
            <if test="isDefault != null">#{isDefault},</if>
            <if test="sort != null">#{sort},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">now(),</if>
        </trim>
    </insert>

    <update id="updateAiLlmConfig" parameterType="com.ruoyi.system.domain.AiLlmConfig">
        update ai_llm_config
        <trim prefix="SET" suffixOverrides=",">
            <if test="configName != null and configName != ''">config_name = #{configName},</if>
            <if test="provider != null and provider != ''">provider = #{provider},</if>
            <if test="providerName != null and providerName != ''">provider_name = #{providerName},</if>
            <if test="baseUrl != null">base_url = #{baseUrl},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="defaultModel != null">default_model = #{defaultModel},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = now(),</if>
        </trim>
        where config_id = #{configId}
    </update>

    <delete id="deleteAiLlmConfigById" parameterType="Long">
        delete from ai_llm_config where config_id = #{configId}
    </delete>

    <delete id="deleteAiLlmConfigByIds" parameterType="Long">
        delete from ai_llm_config where config_id in
        <foreach item="configId" collection="array" open="(" separator="," close=")">
            #{configId}
        </foreach>
    </delete>

    <update id="clearDefault">
        update ai_llm_config set is_default = '0'
    </update>

</mapper>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiConversationMapper">

    <resultMap type="com.ruoyi.system.domain.AiConversation" id="AiConversationResult">
        <result property="conversationId" column="conversation_id"/>
        <result property="title" column="title"/>
        <result property="llmConfigId" column="llm_config_id"/>
        <result property="promptTemplateId" column="prompt_template_id"/>
        <result property="kbId" column="kb_id"/>
        <result property="memoryMode" column="memory_mode"/>
        <result property="maxTokens" column="max_tokens"/>
        <result property="messageCount" column="message_count"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectConversationVo">
        select conversation_id, title, llm_config_id, prompt_template_id, kb_id,
               memory_mode, max_tokens, message_count, status,
               create_by, create_time, update_by, update_time
        from ai_conversation
    </sql>

    <select id="selectAiConversationById" parameterType="Long" resultMap="AiConversationResult">
        <include refid="selectConversationVo"/>
        where conversation_id = #{conversationId}
    </select>

    <select id="selectAiConversationList" parameterType="com.ruoyi.system.domain.AiConversation" resultMap="AiConversationResult">
        <include refid="selectConversationVo"/>
        <where>
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="createBy != null and createBy != ''">
                and create_by = #{createBy}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by update_time desc
    </select>

    <insert id="insertAiConversation" parameterType="com.ruoyi.system.domain.AiConversation" useGeneratedKeys="true" keyProperty="conversationId">
        insert into ai_conversation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null">title,</if>
            <if test="llmConfigId != null">llm_config_id,</if>
            <if test="promptTemplateId != null">prompt_template_id,</if>
            <if test="kbId != null">kb_id,</if>
            <if test="memoryMode != null">memory_mode,</if>
            <if test="maxTokens != null">max_tokens,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null">#{title},</if>
            <if test="llmConfigId != null">#{llmConfigId},</if>
            <if test="promptTemplateId != null">#{promptTemplateId},</if>
            <if test="kbId != null">#{kbId},</if>
            <if test="memoryMode != null">#{memoryMode},</if>
            <if test="maxTokens != null">#{maxTokens},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAiConversation" parameterType="com.ruoyi.system.domain.AiConversation">
        update ai_conversation
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null">title = #{title},</if>
            <if test="llmConfigId != null">llm_config_id = #{llmConfigId},</if>
            <if test="promptTemplateId != null">prompt_template_id = #{promptTemplateId},</if>
            <if test="kbId != null">kb_id = #{kbId},</if>
            <if test="memoryMode != null">memory_mode = #{memoryMode},</if>
            <if test="maxTokens != null">max_tokens = #{maxTokens},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where conversation_id = #{conversationId}
    </update>

    <update id="updateMessageCount" parameterType="Long">
        update ai_conversation
        set message_count = (select count(1) from ai_conversation_message where conversation_id = #{conversationId}),
            update_time = sysdate()
        where conversation_id = #{conversationId}
    </update>

    <delete id="deleteAiConversationById" parameterType="Long">
        delete from ai_conversation where conversation_id = #{conversationId}
    </delete>

    <delete id="deleteAiConversationByIds" parameterType="String">
        delete from ai_conversation where conversation_id in
        <foreach collection="array" item="conversationId" open="(" separator="," close=")">
            #{conversationId}
        </foreach>
    </delete>

</mapper>
